# linux-av configuration — copy to one of these (first found wins):
#   $XDG_CONFIG_HOME/linux-av/av.env   (~/.config/linux-av/av.env)  per-user
#   /etc/linux-av/av.env                                            system-wide
#   <repo>/config/av.env                                           repo-local
#
# Every value is optional; shown here with its built-in default. All are plain
# env vars, so you can also export them ad-hoc instead of using this file.

# What to scan when no --path/--full/--quick is given. Space-separated.
# Default: the invoking user's home.
#AV_SCAN_PATHS="$HOME"

# Directories the standalone scanner must never descend into.
#AV_EXCLUDE_DIRS="/proc /sys /dev /run /var/lib/clamav"

# Engine: auto (prefer the daemon if its socket exists), or force one.
#AV_ENGINE="auto"

# Where logs, state and quarantined files go. Defaults follow the XDG spec so
# they land in the user's home unless you point them at a system path.
#AV_LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/linux-av"
#AV_LOG_FILE="$AV_LOG_DIR/av-scan.log"
#AV_QUARANTINE="$AV_LOG_DIR/quarantine"

# clamd socket, if auto-detection fails. Common values:
#   Arch / Debian / Ubuntu default:  /run/clamav/clamd.ctl
#AV_CLAMD_SOCKET="/run/clamav/clamd.ctl"

# Move infected files to quarantine automatically (same as passing -q).
#AV_QUARANTINE_ON=0

# Shell command to run when threats are found (alerting hook). Example:
#AV_ON_FOUND='logger -t linux-av "threat found on $(hostname)"'

# Basename for the installed systemd timer/service units.
#AV_TIMER_NAME="linux-av-scan"

# Color: auto | always | never
#AV_COLOR="auto"
