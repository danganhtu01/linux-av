#!/usr/bin/env bash
# av-setup — install and enable the AV / protection stack, the right way for
#            this distro (Arch / Debian / Ubuntu).
#
#   av-setup install     install packages: clamav rkhunter chkrootkit aide audit
#   av-setup enable       seed signatures + enable the systemd services
#   av-setup onaccess     enable ClamAV real-time (on-access) scanning
#   av-setup status       show what is installed / running
#   av-setup all          install + enable (the usual first-run)
#
# Needs root; it will re-exec itself through sudo if you forget.

set -uo pipefail

_src="${BASH_SOURCE[0]}"
while [ -L "$_src" ]; do
    _dir="$(cd -P "$(dirname "$_src")" && pwd)"; _src="$(readlink "$_src")"
    [ "${_src#/}" = "$_src" ] && _src="$_dir/$_src"
done
AV_HOME="$(cd -P "$(dirname "$_src")/.." && pwd)"; export AV_HOME
# shellcheck source=../lib/common.sh
. "$AV_HOME/lib/common.sh"
av_detect_distro

# ---------------------------------------------------------------------------
do_install() {
    log_info "distro=$AV_DISTRO_ID family=$AV_FAMILY pkg=$AV_PKG_MGR"

    if [ "$AV_FAMILY" = debian ]; then
        apt-get update -y
        # All official on Debian/Ubuntu — a single transaction is fine.
        # shellcheck disable=SC2046
        av_pkg_install $(av_pkg_names clamav) $(av_pkg_names rkhunter) \
                       $(av_pkg_names aide) $(av_pkg_names audit) \
                       $(av_pkg_names chkrootkit)
    else
        # Arch: install official-repo packages ONE AT A TIME so an unavailable
        # target can't abort the whole batch (clamav + rkhunter are in extra,
        # audit in core). aide + chkrootkit are AUR-only and makepkg refuses to
        # run as root, so they cannot be installed here — warn instead.
        local p
        for p in clamav rkhunter audit; do
            log_info "installing $p ..."
            pacman -S --needed --noconfirm "$p" \
                || log_warn "could not install '$p' — try 'sudo pacman -Syu' then rerun"
        done
        for p in aide chkrootkit; do
            if have "$p"; then
                log_info "$p already present (AUR)"
            elif [ "$p" = aide ]; then
                log_warn "'aide' is AUR-only on Arch and won't build against nettle 3.10+."
                log_warn "  Install it (built against libgcrypt) as your normal user:  av-aide-arch"
            else
                log_warn "'$p' is AUR-only on Arch (can't build as root) — install as a normal user:  yay -S $p"
            fi
        done
    fi
    log_info "package install step done."
}

# ---------------------------------------------------------------------------
do_enable() {
    have systemctl || die "no systemd on this box (unexpected)"

    if [ "$AV_FAMILY" = arch ]; then
        # Arch enables NOTHING automatically and clamd won't start without a DB.
        if ! have freshclam; then
            log_warn "clamav not installed — skipping DB seed + service enable (fix 'av-setup install' first)"
        else
            # Arch ships /etc/clamav/{freshclam,clamd}.conf with a literal
            # 'Example' line that makes ClamAV refuse to start until it's removed.
            for cf in /etc/clamav/freshclam.conf /etc/clamav/clamd.conf; do
                if [ -f "$cf" ] && grep -q '^Example' "$cf"; then
                    sed -i 's/^Example/#Example/' "$cf" && log_info "disabled 'Example' line in $cf"
                fi
            done
            log_info "seeding virus DB (freshclam) — required before clamd starts ..."
            freshclam || log_warn "freshclam failed; check /etc/clamav/freshclam.conf"
            log_info "enabling clamav-freshclam + clamav-daemon ..."
            systemctl enable --now clamav-freshclam.service || log_warn "enable clamav-freshclam failed"
            systemctl enable --now clamav-daemon.service    || log_warn "enable clamav-daemon failed"
        fi
        log_info "enabling auditd ..."
        systemctl enable --now auditd.service || log_warn "enable auditd failed (is the 'audit' package installed?)"
    else
        # Debian/Ubuntu auto-enable clamav-freshclam, clamav-daemon and auditd
        # at install time. Just make sure they're up and the DB is seeded.
        log_info "Debian/Ubuntu auto-enable these at install; ensuring they are running ..."
        systemctl enable --now clamav-freshclam.service 2>/dev/null || true
        # clamd may be waiting on the first DB download; nudge it.
        systemctl start clamav-daemon.service 2>/dev/null || true
        systemctl enable --now auditd.service 2>/dev/null || true
    fi

    # AIDE baseline (path/binary differs by family).
    if have aide || have aide.wrapper; then
        log_info "building AIDE baseline (one-time, can be slow) ..."
        if [ "$AV_FAMILY" = debian ]; then
            aideinit -y -f || log_warn "aideinit failed"
        else
            aide --init && mv -f /var/lib/aide/aide.db.new.gz /var/lib/aide/aide.db.gz \
                || log_warn "aide --init failed"
        fi
    fi

    log_info "done. Check with: av-setup status"
}

# ---------------------------------------------------------------------------
do_onaccess() {
    local conf=/etc/clamav/clamd.conf
    [ -f "$conf" ] || die "$conf not found — run 'av-setup install' first"

    # On-access CANNOT watch the whole root filesystem — pick a sane target.
    # Prefer AV_ONACCESS_PATHS; else the scan paths; but never '/'.
    local watch="${AV_ONACCESS_PATHS:-$AV_SCAN_PATHS}"
    case " $watch " in
        *" / "*|"/") watch="/home"
            log_warn "on-access can't watch '/' (whole root) — watching $watch instead."
            log_warn "  set AV_ONACCESS_PATHS='/home /srv ...' to choose." ;;
    esac

    # clamd runs as this user; clamonacc REFUSES to start unless the scanner's own
    # user is excluded, or it loops forever (scanning its own reads). Required.
    local clamuser; clamuser="$(awk '/^User[ \t]/{print $2; exit}' "$conf")"
    : "${clamuser:=clamav}"

    if grep -q '^OnAccessIncludePath' "$conf"; then
        log_info "on-access already configured in $conf — leaving it as-is"
    else
        {
            echo ""
            echo "# added by linux-av av-setup onaccess"
            local p; for p in $watch; do echo "OnAccessIncludePath $p"; done
            echo "OnAccessExcludeUname $clamuser"   # required: breaks the scan loop
            echo "OnAccessPrevention yes"           # block access to infected files
        } >> "$conf"
        log_info "configured on-access in $conf (watch: $watch, exclude user: $clamuser)"
    fi

    # clamd must re-read clamd.conf before clamonacc connects.
    systemctl restart clamav-daemon.service 2>/dev/null || true
    systemctl reset-failed clamav-clamonacc.service 2>/dev/null || true
    if systemctl enable --now clamav-clamonacc.service; then
        log_info "real-time scanning enabled (clamav-clamonacc.service), watching: $watch"
    else
        log_warn "clamav-clamonacc failed — check: journalctl -u clamav-clamonacc"
    fi
}

# ---------------------------------------------------------------------------
do_status() {
    printf '== linux-av setup status ==\n'
    printf 'distro: %s (family=%s)\n\n' "$AV_DISTRO_ID" "$AV_FAMILY"
    local c
    for c in clamscan clamdscan freshclam rkhunter chkrootkit aide aide.wrapper auditctl; do
        if have "$c"; then printf '  [x] %s\n' "$c"; else printf '  [ ] %s (missing)\n' "$c"; fi
    done
    echo
    if have systemctl; then
        for s in clamav-daemon clamav-freshclam clamav-clamonacc auditd; do
            printf '  %-20s %s\n' "$s" "$(systemctl is-active "$s.service" 2>/dev/null || true)"
        done
    fi
}

# Escalate to root ONCE, preserving the full command, so composite commands like
# `all` run install AND enable as root. (A per-function re-exec with `exec` would
# replace the process and silently drop the rest of the sequence.)
case "${1:-}" in
    install|enable|onaccess|all)
        if [ "$(id -u)" -ne 0 ]; then
            have sudo || die "must run as root and sudo not found"
            log_warn "escalating with sudo ..."
            exec sudo -E "$0" "$@"
        fi ;;
esac

case "${1:-}" in
    install)  do_install ;;
    enable)   do_enable ;;
    onaccess) do_onaccess ;;
    status)   do_status ;;
    all)      do_install; do_enable ;;
    ""|-h|--help)
        sed -n '2,17p' "$0" | sed 's/^# \{0,1\}//' ;;
    *) die "unknown command: $1 (try: install | enable | onaccess | status | all)" ;;
esac
